# Agent Management
PORT=8091
ALLOWED_ORIGINS=*

# Foundry model used for prompt generation
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5.4
AZURE_OPENAI_API_VERSION=preview
AZURE_TENANT_ID=your-tenant-id
APP_CLIENT_ID=your-app-client-id
APP_CLIENT_SECRET=your-app-client-secret

# Azure Cosmos DB project store
AGENT_MGMT_COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
AGENT_MGMT_COSMOS_DATABASE=agents
AGENT_MGMT_COSMOS_CONTAINER=agentmetadata
AGENT_MGMT_COSMOS_PARTITION_KEY=/projectid
AGENT_MGMT_COSMOS_CREATE_IF_MISSING=true
AGENT_MGMT_COSMOS_AUTH_MODE=service_principal
AGENT_MGMT_PERMISSIONS_DATABASE=permissions
AGENT_MGMT_PERMISSIONS_CONTAINER=roles
AGENT_MGMT_PERMISSIONS_PARTITION_KEY=/roleid
AGENT_MGMT_ALLOW_LOCAL_STORE=true

# Fabric discovery and Power BI query tokens are delegated from the signed-in user.
FABRIC_CORE_MCP_ENDPOINT=https://api.fabric.microsoft.com/v1/mcp/core

# Foundry hosted-agent deployment settings
FOUNDRY_PROJECT_ENDPOINT=https://your-foundry-project.services.ai.azure.com/api/projects/your-project
FOUNDRY_API_VERSION=v1
FOUNDRY_FEATURES=HostedAgents=V1Preview
ACR_LOGIN_SERVER=your-acr.azurecr.io
ACR_NAME=your-acr
HOSTED_AGENT_IMAGE=your-acr.azurecr.io/hosted-agent-runtime:latest
CUSTOM_UX_CONFIG_PATH=../custom_ux/.env
