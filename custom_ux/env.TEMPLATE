# ── Foundry Hosted Agents ─────────────────────────────────────
FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry-project>.services.ai.azure.com/api/projects/<your-project>
FOUNDRY_API_VERSION=v1
FOUNDRY_FEATURES=HostedAgents=V1Preview

# ── Azure OpenAI (used by Mem0 via Foundry endpoint) ─────────
AZURE_OPENAI_DEPLOYMENT_NAME=<your-deployment-name>

# ── Mem0 memory ──────────────────────────────────────────────
AOAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-small
AOAI_EMBEDDING_API_VERSION=2024-06-01
AZURE_AI_SEARCH_SERVICE_NAME=<your-search-service>
AZURE_AI_SEARCH_API_KEY=<your-search-key>

# ── Server config ────────────────────────────────────────────
PORT=8080

# ── Azure Identity (for Cosmos + Foundry) ────────────────────
AZURE_TENANT_ID=<your-tenant-id>
APP_CLIENT_ID=<your-app-client-id>
APP_CLIENT_SECRET=<your-app-client-secret>

# ── Cosmos DB (permissions / roles) ──────────────────────────
AGENT_MGMT_COSMOS_ENDPOINT=https://<your-cosmos>.documents.azure.com:443/
AGENT_MGMT_PERMISSIONS_DATABASE=permissions
AGENT_MGMT_PERMISSIONS_CONTAINER=roles
AGENT_MGMT_BOOTSTRAP_ADMIN_OBJECT_IDS=
CUSTOM_UX_HISTORY_DATABASE=customux
CUSTOM_UX_HISTORY_CONTAINER=conversationhistory
CUSTOM_UX_HISTORY_PARTITION_KEY=/userid
